# Starship Configuration
# https://starship.rs/config/

right_format = """$cmd_duration$status"""

# Configure the fill module character (can be a space or a symbol)
# Unused but can add $fill to the format so that left aka $format and $right_format are
# seperated by many $fill
[fill]
symbol = " " # Empty space pushing items to the right

# Some toolchains (notably Node via mise on macOS) can exceed 2s on cold start.
# Raise timeout to avoid spurious prompt warnings.
command_timeout = 5000
add_newline = true
# Palette driven by starship_palette in .chezmoidata/themes.toml
palette = "catppuccin_mocha"

[character]
#success_symbol = "[‚ěú](bold green)"
#error_symbol = "[‚ěú](bold red)"
#vicmd_symbol = "[‚Ěģ](green bold)"
# capsule
success_symbol = "[‚ěú](bold #81a1c1)"
error_symbol = "[‚ěú](bold #bf616a)"
vicmd_symbol = "[‚Ěģ](bold #a3be8c)"

[package]
disabled = true

[git_branch]
#symbol = "> "
#symbol = "ūüĆŅ "
#style = "bold yellow"
#style = "bg:#b16286 fg:#ffffff"
#format = "on [$symbol$branch]($style) "

#style = "bg:#d14949 fg:#ffffff bold"
#format = "[Óāį](fg:#801b29 bg:#d14949)[ $symbol$branch ]($style)"

# "Soft Capsule" (Using Rounded Glyphs)
#symbol = "Ôźė "
#style = "bg:#3b4252 fg:#b48ead bold"
#format = "[Óā∂](fg:#3b4252)[$symbol$branch]($style)[Óāī](fg:#3b4252) "

symbol = "Ôźė "
style = "bg:#3b4252 fg:#b48ead bold" # Soft Lavender text on Medium Graphite
# Left side of the capsule: opens with Óā∂, but does NOT close with Óāī
format = "[Óā∂](fg:#3b4252)[$symbol$branch]($style)"

# Cyberpunk Slash" (Using Angled Glyphs)
#symbol = "ÔĄď "
#style = "bg:#89b4fa fg:#1e1e2e bold"
#format = "[Óāł](fg:#1e1e2e bg:#89b4fa)[ $symbol$branch ]($style)"


[git_status]
disabled = false
#style = "bold red"
#style = "bg:#d14949 fg:#ffffff"
#format = "[$all_status$ahead_behind ]($style)"
# capsule
#style = "bg:#3b4252 fg:#bf616a" # Soft Coral/Red for changes
#format = "[Óā∂](fg:#3b4252 bg:#3b4252)[$all_status$ahead_behind]($style)[Óāī](fg:#3b4252) "

#style = "bg:#3b4252 fg:#b48ead bold"
# style = "bg:#3b4252 fg:#bf616a" # Soft Coral/Red for changes
# Right side of the capsule: adds a space, displays status, and closes with Óāī
# format = "[ $all_status$ahead_behind]($style)[Óāī](fg:#3b4252) "

# format = "[ $all_status$ahead_behind](bg:#3b4252 fg:#b48ead bold)[Óāī](fg:#3b4252) "

style = "bg:#3b4252 fg:#f97316 bold"
# Note: The space is placed inside the styling bracket so it stays clean
format = "[$all_status$ahead_behind]($style)[Óāī](fg:#3b4252) "

[hostname]
ssh_only = false
trim_at = "."
#format = "[$hostname](bold blue) "
disabled = false
style = "bg:#2e3440 fg:#ebcb8b bold"
# Wrapped in rounded glyphs with matching fg coloring
format = "[Óā∂](fg:#2e3440)[ůįíč $hostname]($style)[Óāī](fg:#2e3440) "

[username]
#style_user = "white bold"
#style_root = "black bold"
#format = "[$user]($style) "
disabled = false
show_always = false
style_user = "bg:#2e3440 fg:#ebcb8b bold"
format = "[Óā∂](fg:#2e3440)[ůį≠Ļ $user]($style)[Óāī](fg:#2e3440) "

[directory]
truncation_length = 4
truncation_symbol = "‚Ä¶/"
read_only = " ůįĆĺ"
# "Flame Gradient" (Warm Monochromatic
#style = "bg:#458588 fg:#000000"
#style = "bg:#801b29 fg:#ffffff bold"
#format = "[Óāį](fg:#4a121a bg:#801b29)[ $path ]($style)"

# "Soft Capsule" (Using Rounded Glyphs)
#
style = "bg:#2e3440 fg:#ebcb8b bold" # Minty Frost Blue text on Dark Graphite
format = "[Óā∂](fg:#2e3440)[ůįČč $path]($style)[Óāī](fg:#2e3440) "

# Cyberpunk Slash" (Using Angled Glyphs)
#style = "bg:#1e1e2e fg:#f107a3 bold"
#format = "[Óāł](fg:#f107a3 bg:#1e1e2e)[ ůįĚį $path ]($style)"

[cmd_duration]
min_time = 0
# format = "took [$duration]($style) "
show_milliseconds = true

# "Soft Capsule" (Using Rounded Glyphs)
style = "bg:#2e3440 fg:#d8dee9" # Neutral Slate text
format = "[Óā∂](fg:#2e3440)[ůĪéę $duration]($style)[Óāī](fg:#2e3440) "

# ---------- Language version indicators ---------- #
[rust]
#format = "[$symbol($version)]($style) "
#symbol = "rs "
disabled = false
style = "bg:#2e3440 fg:#a3be8c bold"
format = "[Óā∂](fg:#2e3440)[ūü¶Ä $version]($style)[Óāī](fg:#2e3440) "

[bun]
disabled = false
style = "bg:#2e3440 fg:#a3be8c bold"
format = "[Óā∂](fg:#2e3440)[ūü•ü $version]($style)[Óāī](fg:#2e3440) "

[mise]
disabled = false
#format = "via [ůįĚ§ mise $version]($style) "
#style = "green bold"
style = "bg:#2e3440 fg:#a3be8c bold"
format = "[Óā∂](fg:#2e3440)[ůĪĀē mise]($style)[Óāī](fg:#2e3440) "

[python]
#format = "[$symbol$pyenv_prefix($version)( \\($virtualenv\\))]($style) "
#symbol = "py "
#capsule
symbol = "ūüźć "
style = "bg:#2e3440 fg:#a3be8c bold" # Soft Sage/Muted Yellow text
format = "[Óā∂](fg:#2e3440)[$symbol$version]($style)[Óāī](fg:#2e3440) "

[nodejs]
#format = "[$symbol($version)]($style) "
#symbol = "node "
detect_files = ["package.json", ".node-version"]
symbol = "ůįéô "
# capsule
style = "bg:#2e3440 fg:#a3be8c bold" # Muted Olive Green text
format = "[Óā∂](fg:#2e3440)[$symbol$version]($style)[Óāī](fg:#2e3440) "

[golang]
#format = "[$symbol($version)]($style) "
#symbol = "go "
disabled = false
style = "bg:#88c0d0 fg:#a3be8c bold"
format = "[Óā∂](fg:#2e3440)[Óėß $version]($style)[Óāī](fg:#2e3440) "

# ---------- Docker context ---------- #
[docker_context]
#format = "[$symbol$context]($style) "
#symbol = "docker "
disabled = false
style = "bg:#2e3440 fg:#88c0d0 bold"
format = "[Óā∂](fg:#2e3440)[ůį°® $context]($style)[Óāī](fg:#2e3440) "
only_with_files = true
detect_files = ["docker-compose.yml", "docker-compose.yaml", "Dockerfile"]

# ---------- Shell nesting level ---------- #
[shlvl]
disabled = false
threshold = 2
#symbol = "‚Üē "
#format = "[$symbol$shlvl]($style) "
style = "bg:#2e3440 fg:#88c0d0 bold"
format = "[Óā∂](fg:#2e3440)[‚Üē SHLVL $shlvl]($style)[Óāī](fg:#2e3440) "

# ---------- Exit status ---------- #
[status]
disabled = false
#format = "[$symbol$status]($style) "
#symbol = "‚úė "
# show_always = true line replaced with disabled false above
style = "bg:#2e3440 fg:#bf616a bold" # Soft Nord Red for errors
success_symbol = ""
format = "[Óā∂](fg:#2e3440)[ůįöĆ $int]($style)[Óāī](fg:#2e3440) "

# ---------- Kubernetes context ---------- #
[kubernetes]
disabled = false
#format = "[$symbol$context( \\($namespace\\))]($style) "
#symbol = "k8s "
#style = "bold cyan"
detect_files = ["k8s", "kubernetes", "Tiltfile"]
detect_folders = ["charts", "kustomize"]
style = "bg:#2e3440 fg:#88c0d0 bold"
format = "[Óā∂](fg:#2e3440)[ůĪÉĺ $context]($style)[Óāī](fg:#2e3440) "

[kubernetes.context_aliases]
#"arn:aws:eks:.*:.*:cluster/(?P<name>.*)" = "$name"
"gke_.*_.*_(.*)" = "gke-$1"
"arn:aws:eks:.*:.*:cluster/(.*)" = "eks-$1"

[aws]
#symbol = "ůįłŹ "
disabled = false
#format = "on [$symbol$profile(\\($region\\))]($style) "
#style = "amber bold"
style = "bg:#2e3440 fg:#88c0d0 bold"
format = "[Óā∂](fg:#2e3440)[ůįłŹ $profile]($style)[Óāī](fg:#2e3440) "

# ---------- Nix shell indicator ---------- #
[nix_shell]
disabled = false
#format = "[$symbol$state( \\($name\\))]($style) "
#symbol = "nix "
#style = "bold blue"
style = "bg:#2e3440 fg:#88c0d0 bold"
format = "[Óā∂](fg:#2e3440)[ÔĆď $state]($style)[Óāī](fg:#2e3440) "

# ---------- Direnv indicator ---------- #
# Disabled: starship reads direnv state before the hook sets DIRENV_DIR,
# causing "[WARN] unknown direnv state" on every prompt render.
# Direnv itself still works ‚ÄĒ only the starship status indicator is hidden.
[direnv]
disabled = true

# ---------- Pueue Tasks (Background daemon) ---------- #
[custom.pueue]
command = "n=$(pueue status -j 2>/dev/null | jq -r '[.tasks[] | select(.status == \"Running\" or .status == \"Queued\")] | length' 2>/dev/null) && [ \"$n\" != \"0\" ] && echo \"$n\""
when = "command -v pueue >/dev/null && command -v jq >/dev/null"
ignore_timeout = true
symbol = "‚öô "
style = "bold purple"
format = "[$symbol$output]($style) "

# ---------- Container-aware fallback ---------- #
# When DOTFILES_CONTAINER=1, show a lightweight indicator so the user
# knows they are inside a container.  Uses only ASCII-safe characters
# to avoid rendering issues with missing Nerd Fonts.

[container]
disabled = false
symbol = "[ctr]"
style = "bold dimmed blue"
format = '[$symbol]($style) '

[env_var.DOTFILES_CONTAINER]
variable = "DOTFILES_CONTAINER"
symbol = ""
style = "bold dimmed cyan"
format = '[container]($style) '

[env_var.DOTFILES_CODESPACE]
variable = "DOTFILES_CODESPACE"
symbol = ""
style = "bold dimmed green"
format = '[codespace]($style) '

[env_var.DOTFILES_LAYERS_LOAD_STATUS]
variable = "DOTFILES_LAYERS_LOAD_STATUS"
symbol = ""
style = "bold dimmed yellow"
format = '[‚ÄĘ]($style) '

